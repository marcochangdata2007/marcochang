<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Merry Christmas | 聖誕快樂 | 圣诞快乐</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', 'Microsoft JhengHei', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background: linear-gradient(to bottom, #0a2342, #1a3a5f);
            color: #f8f9fa;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 20px;
            overflow-x: hidden;
        }

        /* 語言切換按鈕 */
        .language-switcher {
            position: absolute;
            top: 20px;
            right: 20px;
            display: flex;
            gap: 10px;
            z-index: 100;
        }
        .lang-btn {
            padding: 8px 16px;
            border: none;
            border-radius: 20px;
            background: rgba(255, 255, 255, 0.15);
            color: white;
            cursor: pointer;
            transition: all 0.3s;
            font-weight: bold;
            backdrop-filter: blur(5px);
            font-size: 0.9rem;
        }
        .lang-btn:hover {
            background: rgba(255, 255, 255, 0.25);
            transform: translateY(-2px);
        }
        .lang-btn.active {
            background: #c93c3c;
            box-shadow: 0 0 10px rgba(201, 60, 60, 0.7);
        }

        /* 標題區域 */
        header {
            text-align: center;
            margin-bottom: 30px;
            padding: 15px;
            width: 100%;
            max-width: 800px;
            border-bottom: 2px dashed #c93c3c;
        }
        h1 {
            font-size: 2.8rem;
            margin-bottom: 10px;
            text-shadow: 3px 3px 0 #c93c3c, 6px 6px 0 rgba(0, 0, 0, 0.2);
            letter-spacing: 2px;
            color: #f1faee;
        }
        .subtitle {
            font-size: 1.2rem;
            color: #a8dadc;
            font-style: italic;
        }

        /* 主容器 */
        .main-container {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 40px;
            max-width: 1200px;
            margin-bottom: 30px;
        }

        /* 左側聖誕樹區域 */
        .tree-section {
            flex: 1;
            min-width: 350px;
            text-align: center;
            position: relative;
        }
        
        /* 真實聖誕樹圖片容器 */
        #tree-container {
            position: relative;
            width: 350px;
            height: 500px;
            margin: 0 auto 30px;
            background-image: url('https://images.unsplash.com/photo-1606830733741-9686ba71ede7?w=400&fit=crop');
            background-size: contain;
            background-repeat: no-repeat;
            background-position: center bottom;
            border-radius: 10px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
        }
        
        /* 裝飾品圖片樣式 */
        .ornament {
            position: absolute;
            cursor: grab;
            transition: transform 0.2s, filter 0.3s;
            z-index: 10;
            box-shadow: 0 4px 8px rgba(0,0,0,0.3);
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .ornament:active {
            cursor: grabbing;
            transform: scale(1.1);
        }
        .ornament:hover {
            filter: brightness(1.2) drop-shadow(0 0 5px gold);
        }
        .ornament-img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }

        /* 禮物區域 */
        #gifts-container {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-top: 20px;
            flex-wrap: wrap;
        }
        .gift {
            width: 70px;
            height: 70px;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            box-shadow: 0 5px 15px rgba(0,0,0,0.5);
            overflow: hidden;
            border: 2px solid transparent;
        }
        .gift:hover {
            transform: translateY(-10px) scale(1.1);
            border-color: gold;
        }
        .gift-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        /* 右側控制面板 */
        .controls-section {
            flex: 1;
            min-width: 350px;
            background: rgba(255, 255, 255, 0.08);
            border-radius: 15px;
            padding: 25px;
            border: 1px solid rgba(201, 60, 60, 0.4);
            backdrop-filter: blur(5px);
        }
        h2 {
            color: #ffd166;
            margin-bottom: 20px;
            text-align: center;
            font-size: 1.8rem;
        }

        /* 音樂播放器 */
        .music-player {
            background: rgba(0, 0, 0, 0.2);
            border-radius: 10px;
            padding: 15px;
            margin-bottom: 25px;
            border: 1px solid rgba(255, 209, 102, 0.3);
        }
        .music-info {
            display: flex;
            align-items: center;
            margin-bottom: 10px;
        }
        .music-title {
            flex-grow: 1;
            font-weight: bold;
            color: #ffd166;
        }
        .music-controls {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 10px;
        }
        .music-btn {
            background: rgba(201, 60, 60, 0.7);
            color: white;
            border: none;
            border-radius: 50%;
            width: 40px;
            height: 40px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s;
        }
        .music-btn:hover {
            background: rgba(201, 60, 60, 0.9);
            transform: scale(1.1);
        }
        .song-list {
            display: flex;
            flex-direction: column;
            gap: 10px;
            margin-top: 15px;
        }
        .song-item {
            padding: 10px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 5px;
            cursor: pointer;
            transition: all 0.3s;
        }
        .song-item:hover {
            background: rgba(255, 255, 255, 0.1);
        }
        .song-item.active {
            background: rgba(201, 60, 60, 0.3);
            border-left: 3px solid #c93c3c;
        }

        /* 裝飾品列表 - 使用圖片預覽 */
        .decorator-list {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
            gap: 15px;
            margin-bottom: 30px;
        }
        .decorator-item {
            background: rgba(42, 125, 74, 0.3);
            border-radius: 10px;
            padding: 15px 10px;
            text-align: center;
            cursor: grab;
            border: 2px dashed transparent;
            transition: all 0.3s;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 8px;
        }
        .decorator-item:hover {
            background: rgba(42, 125, 74, 0.5);
            border-color: #ffd166;
            transform: translateY(-3px);
        }
        .decorator-img {
            width: 50px;
            height: 50px;
            object-fit: contain;
            filter: drop-shadow(0 2px 3px rgba(0,0,0,0.3));
        }
        .decorator-name {
            font-size: 0.85rem;
            color: #f1faee;
            font-weight: 500;
        }

        /* 功能按鈕 */
        .action-buttons {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            justify-content: center;
        }
        button {
            padding: 12px 25px;
            border: none;
            border-radius: 50px;
            background: linear-gradient(to right, #c93c3c, #e76f51);
            color: white;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.3s;
            font-size: 1rem;
            letter-spacing: 1px;
            flex: 1;
            min-width: 150px;
            box-shadow: 0 5px 15px rgba(201, 60, 60, 0.4);
        }
        button:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(201, 60, 60, 0.6);
        }
        #resetBtn {
            background: linear-gradient(to right, #1d3557, #457b9d);
            box-shadow: 0 5px 15px rgba(29, 53, 87, 0.4);
        }

        /* 裝飾計數器 */
        .decoration-counter {
            background: rgba(255, 255, 255, 0.1);
            border-radius: 10px;
            padding: 10px 15px;
            margin-top: 15px;
            text-align: center;
            border: 1px solid rgba(255, 209, 102, 0.3);
            backdrop-filter: blur(5px);
        }

        /* 雪花效果 */
        #snowflakes-container {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: -1;
        }
        .snowflake {
            position: absolute;
            background-color: white;
            border-radius: 50%;
            opacity: 0.8;
            top: -10px;
        }

        /* 節日訊息 */
        .festive-message {
            background: rgba(201, 60, 60, 0.2);
            border-radius: 10px;
            padding: 15px;
            margin-top: 20px;
            text-align: center;
            border: 1px solid rgba(255, 209, 102, 0.3);
        }

        /* 響應式設計 */
        @media (max-width: 768px) {
            .main-container {
                flex-direction: column;
                align-items: center;
            }
            .controls-section {
                width: 100%;
            }
            h1 {
                font-size: 2.2rem;
            }
            .language-switcher {
                position: relative;
                top: 0;
                right: 0;
                margin-bottom: 15px;
                justify-content: center;
            }
            #tree-container {
                width: 300px;
                height: 450px;
            }
            .lang-btn {
                padding: 6px 12px;
                font-size: 0.8rem;
            }
        }
    </style>
</head>
