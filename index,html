            setupDragAndDrop: function() {
                this.treeContainer.addEventListener('dragover', (e) => {
                    e.preventDefault();
                });
                
                this.treeContainer.addEventListener('drop', (e) => {
                    e.preventDefault();
                    const index = e.dataTransfer.getData('text/plain');
                    if (index === '') return;
                    
                    const ornament = realOrnaments[index];
                    const rect = this.treeContainer.getBoundingClientRect();
                    
                    // 計算在樹容器內的相對位置
                    const x = e.clientX - rect.left;
                    const y = e.clientY - rect.top;
                    
                    // 確保裝飾品在樹範圍內
                    if (x < 30 || x > rect.width - 30 || y < 80 || y > rect.height - 100) {
                        const message = languageManager.getText(
                            "Please drop the ornament onto the tree area!",
                            "请将装饰品放到圣诞树区域！",
                            "請將裝飾品放到聖誕樹區域！"
                        );
                        this.showToastMessage(message);
                        return;
                    }
                    
                    this.addRealOrnamentToTree(x, y, ornament);
                });
            },
            
            handleDragStart: function(e) {
                const index = e.target.closest('.decorator-item').dataset.index;
                e.dataTransfer.setData('text/plain', index);
                
                // 設置拖拽圖片
                const img = e.target.closest('.decorator-item').querySelector('img');
                if (img) {
                    const dragIcon = document.createElement('img');
                    dragIcon.src = img.src;
                    dragIcon.style.width = '40px';
                    dragIcon.style.height = '40px';
                    dragIcon.style.position = 'absolute';
                    dragIcon.style.left = '-1000px';
                    document.body.appendChild(dragIcon);
                    e.dataTransfer.setDragImage(dragIcon, 20, 20);
                    setTimeout(() => document.body.removeChild(dragIcon), 0);
                }
            },
            
            addRealOrnamentToTree: function(x, y, ornament) {
                const ornamentEl = document.createElement('div');
                ornamentEl.className = 'ornament';
                ornamentEl.style.width = `${ornament.size}px`;
                ornamentEl.style.height = `${ornament.size}px`;
                ornamentEl.style.left = `${x - ornament.size/2}px`;
                ornamentEl.style.top = `${y - ornament.size/2}px`;
                
                const img = document.createElement('img');
                img.className = 'ornament-img';
                img.src = ornament.imageUrl;
                img.alt = languageManager.getOrnamentName(ornament);
                img.onerror = function() {
                    const index = realOrnaments.findIndex(o => o.imageUrl === ornament.imageUrl);
                    if (index !== -1) {
                        this.src = backupImages.ornaments[index % backupImages.ornaments.length];
                    }
                };
                
                ornamentEl.appendChild(img);
                
                // 使裝飾品可拖拽和移除
                ornamentEl.draggable = true;
                ornamentEl.addEventListener('dragstart', (e) => {
                    e.dataTransfer.setData('text/plain', 'move');
                    e.dataTransfer.effectAllowed = 'move';
                    
                    // 設置拖拽圖片
                    const dragIcon = document.createElement('img');
                    dragIcon.src = img.src;
                    dragIcon.style.width = '40px';
                    dragIcon.style.height = '40px';
                    dragIcon.style.position = 'absolute';
                    dragIcon.style.left = '-1000px';
                    document.body.appendChild(dragIcon);
                    e.dataTransfer.setDragImage(dragIcon, 20, 20);
                    setTimeout(() => document.body.removeChild(dragIcon), 0);
                    
                    setTimeout(() => {
                        ornamentEl.remove();
                        const index = this.ornamentsOnTree.indexOf(ornamentEl);
                        if (index > -1) {
                            this.ornamentsOnTree.splice(index, 1);
                            this.updateDecorationCounter();
                            
                            // 顯示移除提示
                            const message = languageManager.getText(
                                "Ornament removed!",
                                "装饰品已移除！",
                                "裝飾品已移除！"
                            );
                            this.showToastMessage(message);
                        }
                    }, 0);
                });
                
                // 雙擊旋轉裝飾品
                let rotation = 0;
                ornamentEl.addEventListener('dblclick', () => {
                    rotation += 45;
                    ornamentEl.style.transform = `scale(1.1) rotate(${rotation}deg)`;
                    ornamentEl.style.transition = 'transform 0.3s ease';
                    
                    // 顯示旋轉提示
                    const message = languageManager.getText(
                        "Ornament rotated! Double-click to rotate again.",
                        "装饰品已旋转！双击再次旋转。",
                        "裝飾品已旋轉！雙擊再次旋轉。"
                    );
                    this.showToastMessage(message, 2000);
                    
                    setTimeout(() => {
                        ornamentEl.style.transform = '';
                    }, 300);
                });
                
                this.treeContainer.appendChild(ornamentEl);
                this.ornamentsOnTree.push(ornamentEl);
                this.updateDecorationCounter();
                
                // 顯示添加成功提示
                const message = languageManager.getText(
                    "Ornament added successfully! Double-click to rotate.",
                    "装饰品添加成功！双击可以旋转。",
                    "裝飾品添加成功！雙擊可以旋轉。"
                );
                this.showToastMessage(message, 2000);
            },
            
