                toast.style.backdropFilter = 'blur(5px)';
                toast.style.border = '1px solid rgba(255, 209, 102, 0.3)';
                toast.style.animation = 'slideUp 0.3s ease';
                
                // 添加動畫
                const style = document.createElement('style');
                style.textContent = `
                    @keyframes slideUp {
                        from { bottom: -50px; opacity: 0; }
                        to { bottom: 20px; opacity: 1; }
                    }
                    @keyframes slideDown {
                        from { bottom: 20px; opacity: 1; }
                        to { bottom: -50px; opacity: 0; }
                    }
                `;
                document.head.appendChild(style);
                
                document.body.appendChild(toast);
                
                // 自動消失
                setTimeout(() => {
                    toast.style.animation = 'slideDown 0.3s ease forwards';
                    setTimeout(() => {
                        if (toast.parentNode) {
                            document.body.removeChild(toast);
                        }
                        document.head.removeChild(style);
                    }, 300);
                }, duration);
            },
            
            showInitialHint: function() {
                setTimeout(() => {
                    if (this.ornamentsOnTree.length === 0) {
                        const message = languageManager.getText(
                            "Welcome to the Real Christmas Tree Decorator! 🎄\n\n1. Drag REAL ornaments from the right panel onto the tree.\n2. Double-click ornaments to rotate them.\n3. Click gift boxes for special surprises!\n4. Toggle lights for a magical effect.\n5. Enjoy authentic Christmas music!\n\nStart decorating now!",
                            "欢迎使用真实圣诞树装饰器！🎄\n\n1. 从右侧面板拖拽真实装饰品到树上。\n2. 双击装饰品可以旋转它们。\n3. 点击礼物盒获得特别惊喜！\n4. 切换灯光获得魔法效果。\n5. 欣赏真实的圣诞音乐！\n\n现在开始装饰吧！",
                            "歡迎使用真實聖誕樹裝飾器！🎄\n\n1. 從右側面板拖拽真實裝飾品到樹上。\n2. 雙擊裝飾品可以旋轉它們。\n3. 點擊禮物盒獲得特別驚喜！\n4. 切換燈光獲得魔法效果。\n5. 欣賞真實的聖誕音樂！\n\n現在開始裝飾吧！"
                        );
                        alert(message);
                    }
                }, 800);
            },
            
            setupDoubleClickHint: function() {
                // 添加雙擊提示
                const hint = document.createElement('div');
                hint.innerHTML = languageManager.getText(
                    "💡 Tip: Double-click ornaments to rotate them!",
                    "💡 提示：双击装饰品可以旋转它们！",
                    "💡 提示：雙擊裝飾品可以旋轉它們！"
                );
                hint.style.position = 'fixed';
                hint.style.bottom = '60px';
                hint.style.left = '50%';
                hint.style.transform = 'translateX(-50%)';
                hint.style.background = 'rgba(255, 209, 102, 0.9)';
                hint.style.color = '#1a3a5f';
                hint.style.padding = '8px 16px';
                hint.style.borderRadius = '20px';
                hint.style.fontSize = '0.9rem';
                hint.style.fontWeight = 'bold';
                hint.style.zIndex = '999';
                hint.style.boxShadow = '0 3px 10px rgba(0,0,0,0.2)';
                hint.style.display = 'none';
                hint.id = 'doubleClickHint';
                
                document.body.appendChild(hint);
                
                // 當第一個裝飾品被添加時顯示提示
                const originalAddOrnament = this.addRealOrnamentToTree.bind(this);
                this.addRealOrnamentToTree = function(x, y, ornament) {
                    originalAddOrnament(x, y, ornament);
                    
                    // 顯示雙擊提示
                    if (this.ornamentsOnTree.length === 1) {
                        const hint = document.getElementById('doubleClickHint');
                        hint.style.display = 'block';
                        hint.style.animation = 'fadeIn 0.5s ease';
                        
                        // 添加淡入動畫
                        const style = document.createElement('style');
                        style.textContent = `
                            @keyframes fadeIn {
                                from { opacity: 0; }
                                to { opacity: 1; }
                            }
                        `;
                        document.head.appendChild(style);
                        
                        // 5秒後自動隱藏
                        setTimeout(() => {
                            hint.style.opacity = '0';
                            hint.style.transition = 'opacity 0.5s ease';
                            setTimeout(() => {
                                hint.style.display = 'none';
                                document.head.removeChild(style);
                            }, 500);
                        }, 5000);
                    }
                }.bind(this);
            }
        };

        // 更新函數
        function updateDecoratorNames() {
            realTreeDecorator.renderRealDecoratorList();
        }
        
        function updateGiftMessages() {
            document.querySelectorAll('.gift').forEach((gift, index) => {
                const titleText = languageManager.getText("Click for a surprise!", "点击查看惊喜！", "點擊查看驚喜！");
                gift.title = titleText;
            });
        }
        
        function updateMusicInfo() {
            musicPlayer.updateMusicInfo();
        }
        
        function updateDecorationCounter() {
            realTreeDecorator.updateDecorationCounter();
        }
        
        function updateButtonTitles() {
            const playTitle = languageManager.getText(
                musicPlayer.isPlaying ? 'Pause' : 'Play',
                musicPlayer.isPlaying ? '暂停' : '播放',
                musicPlayer.isPlaying ? '暫停' : '播放'
            );
            document.getElementById('playBtn').setAttribute('title', playTitle);
            
            const prevTitle = languageManager.getText('Previous song', '上一首', '上一首');
            document.getElementById('prevBtn').setAttribute('title', prevTitle);
            
            const nextTitle = languageManager.getText('Next song', '下一首', '下一首');
            document.getElementById('nextBtn').setAttribute('title', nextTitle);
            
            const volumeTitle = languageManager.getText('Volume', '音量', '音量');
            document.getElementById('volumeSlider').setAttribute('title', volumeTitle);
        }

        // 初始化所有組件
        document.addEventListener('DOMContentLoaded', function() {
            // 允許音頻自動播放（需要用戶交互）
            document.body.addEventListener('click', function initAudio() {
                if (musicPlayer.audioElement) {
                    musicPlayer.audioElement.load();
                }
                document.body.removeEventListener('click', initAudio);
            }, { once: true });
            
            // 初始化所有管理器
            languageManager.init();
            musicPlayer.init();
            realTreeDecorator.init();
        });

        // 添加全局CSS動畫
        document.addEventListener('DOMContentLoaded', function() {
            const globalStyle = document.createElement('style');
            globalStyle.textContent = `
                .toast-message {
                    font-family: 'Segoe UI', 'Microsoft JhengHei', sans-serif;
                }
                
                /* 響應式字體大小 */
                @media (max-width: 768px) {
                    .toast-message {
                        font-size: 0.9rem;
                        padding: 10px 20px;
                        max-width: 90%;
                        text-align: center;
                    }
                }
                
                /* 裝飾品旋轉動畫 */
                @keyframes rotate {
                    from { transform: rotate(0deg); }
                    to { transform: rotate(360deg); }
                }
                
                /* 燈光閃爍動畫 */
                @keyframes twinkle {
                    0%, 100% { opacity: 1; }
                    50% { opacity: 0.5; }
                }
            `;
            document.head.appendChild(globalStyle);
        });
    </script>
</body>
</html>
