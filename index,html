        // 三語語言管理器
        const languageManager = {
            currentLang: 'en',
            
            init: function() {
                // 設置語言按鈕事件
                document.getElementById('langEN').addEventListener('click', () => this.switchLanguage('en'));
                document.getElementById('langCN').addEventListener('click', () => this.switchLanguage('cn'));
                document.getElementById('langTW').addEventListener('click', () => this.switchLanguage('tw'));
                
                // 初始設置為英文
                this.switchLanguage('en');
            },
            
            switchLanguage: function(lang) {
                this.currentLang = lang;
                
                // 更新按鈕狀態
                document.querySelectorAll('.lang-btn').forEach(btn => {
                    btn.classList.remove('active');
                });
                document.getElementById(`lang${lang.toUpperCase()}`).classList.add('active');
                
                // 更新所有有data-en、data-cn、data-tw屬性的元素
                document.querySelectorAll('[data-en], [data-cn], [data-tw]').forEach(element => {
                    const dataKey = `data-${lang}`;
                    if (element.hasAttribute(dataKey)) {
                        const text = element.getAttribute(dataKey);
                        if (element.tagName === 'INPUT' || element.tagName === 'TEXTAREA') {
                            element.placeholder = text;
                        } else if (element.tagName === 'IMG') {
                            element.alt = text;
                        } else {
                            element.textContent = text;
                        }
                    }
                });
                
                // 更新裝飾品名稱
                updateDecoratorNames();
                
                // 更新禮物提示
                updateGiftMessages();
                
                // 更新音樂信息
                updateMusicInfo();
                
                // 更新按鈕提示
                updateButtonTitles();
            },
            
            getText: function(enText, cnText, twText) {
                switch(this.currentLang) {
                    case 'cn': return cnText;
                    case 'tw': return twText;
                    default: return enText;
                }
            },
            
            getOrnamentName: function(ornament) {
                switch(this.currentLang) {
                    case 'cn': return ornament.nameCn;
                    case 'tw': return ornament.nameTw;
                    default: return ornament.nameEn;
                }
            },
            
            getGiftMessage: function(gift) {
                switch(this.currentLang) {
                    case 'cn': return gift.messageCn;
                    case 'tw': return gift.messageTw;
                    default: return gift.messageEn;
                }
            }
        };

