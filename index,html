            renderSongList: function() {
                const songList = document.getElementById('songList');
                songList.innerHTML = '';
                
                this.songs.forEach((song, index) => {
                    const songItem = document.createElement('div');
                    songItem.className = 'song-item';
                    if (index === this.currentSongIndex) {
                        songItem.classList.add('active');
                    }
                    
                    // 根據當前語言獲取歌曲標題
                    let songTitle;
                    switch(languageManager.currentLang) {
                        case 'cn': songTitle = song.titleCn; break;
                        case 'tw': songTitle = song.titleTw; break;
                        default: songTitle = song.titleEn;
                    }
                    
                    songItem.textContent = `${index + 1}. ${songTitle}`;
                    
                    songItem.addEventListener('click', () => {
                        this.loadSong(index);
                        this.play();
                    });
                    
                    songList.appendChild(songItem);
                });
            },
            
            loadSong: function(index) {
                this.currentSongIndex = index;
                this.audioElement.src = this.songs[index].src;
                
                // 更新UI
                this.updateMusicInfo();
                this.renderSongList();
            },
            
            togglePlay: function() {
                if (this.isPlaying) {
                    this.pause();
                } else {
                    this.play();
                }
            },
            
            play: function() {
                this.audioElement.play().then(() => {
                    this.isPlaying = true;
                    document.getElementById('playBtn').textContent = '⏸';
                    document.getElementById('playBtn').setAttribute('title', 
                        languageManager.getText('Pause', '暂停', '暫停'));
                }).catch(e => {
                    console.log("Audio play failed:", e);
                    alert(languageManager.getText(
                        "Click anywhere on page to enable audio, then try again.",
                        "请点击页面任意处启用音频，然后重试。",
                        "請點擊頁面任意處啟用音頻，然後重試。"
                    ));
                });
            },
            
            pause: function() {
                this.audioElement.pause();
                this.isPlaying = false;
                document.getElementById('playBtn').textContent = '▶';
                document.getElementById('playBtn').setAttribute('title',
                    languageManager.getText('Play', '播放', '播放'));
            },
            
            prevSong: function() {
                let newIndex = this.currentSongIndex - 1;
                if (newIndex < 0) newIndex = this.songs.length - 1;
                this.loadSong(newIndex);
                if (this.isPlaying) {
                    this.play();
                }
            },
            
            nextSong: function() {
                let newIndex = this.currentSongIndex + 1;
                if (newIndex >= this.songs.length) newIndex = 0;
                this.loadSong(newIndex);
                if (this.isPlaying) {
                    this.play();
                }
            },
            
            setVolume: function(value) {
                const volume = value / 100;
                this.audioElement.volume = volume;
                
                // 更新音量圖標
                const volumeIcon = document.getElementById('volumeIcon');
                if (volume === 0) {
                    volumeIcon.textContent = '🔇';
                } else if (volume < 0.5) {
                    volumeIcon.textContent = '🔉';
                } else {
                    volumeIcon.textContent = '🔊';
                }
            },
            
            updateTime: function() {
                const current = this.audioElement.currentTime;
                const duration = this.audioElement.duration || 0;
                
                const formatTime = (time) => {
                    const mins = Math.floor(time / 60);
                    const secs = Math.floor(time % 60);
                    return `${mins}:${secs < 10 ? '0' : ''}${secs}`;
                };
                
                document.getElementById('musicTime').textContent = 
                    `${formatTime(current)} / ${formatTime(duration)}`;
            },
            
            updateMusicInfo: function() {
                const currentSong = this.songs[this.currentSongIndex];
                let songTitle;
                switch(languageManager.currentLang) {
                    case 'cn': songTitle = currentSong.titleCn; break;
                    case 'tw': songTitle = currentSong.titleTw; break;
                    default: songTitle = currentSong.titleEn;
                }
                document.getElementById('currentSong').textContent = songTitle;
            },
            
            getCurrentSongTitle: function() {
                const currentSong = this.songs[this.currentSongIndex];
                switch(languageManager.currentLang) {
                    case 'cn': return currentSong.titleCn;
                    case 'tw': return currentSong.titleTw;
                    default: return currentSong.titleEn;
                }
            }
        };

